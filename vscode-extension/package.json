{
    "name": "software-debugger",
    "displayName": "Autonomous Software Debugger",
    "description": "AI-powered codebase analysis, bug detection, and diagram generation.",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [],
    "main": "./out/extension.js",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "software-debugger-explorer",
                    "title": "Software Debugger",
                    "icon": "resources/icon.svg"
                }
            ]
        },
        "views": {
            "software-debugger-explorer": [
                {
                    "type": "webview",
                    "id": "software-debugger.view",
                    "name": "Debugger & Visualizer"
                }
            ]
        },
        "commands": [
            {
                "command": "software-debugger.analyzeWorkspace",
                "title": "Analyze Local Workspace"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "node ./out/test/runTest.js"
    },
    "devDependencies": {
        "@types/vscode": "^1.80.0",
        "@types/glob": "^8.1.0",
        "@types/mocha": "^10.0.1",
        "@types/node": "20.x",
        "@typescript-eslint/eslint-plugin": "^5.59.8",
        "@typescript-eslint/parser": "^5.59.8",
        "eslint": "^8.41.0",
        "glob": "^8.1.0",
        "mocha": "^10.2.0",
        "typescript": "^5.1.3",
        "@vscode/test-electron": "^2.3.2"
    }
}